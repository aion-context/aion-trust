 /// Decode a hex string into a fixed-size array, erroring on the wrong length.
 pub fn decode_array<const N: usize>(s: &str) -> Result<[u8; N]> {
     let v = from_hex(s)?;
     v.try_into()
         .map_err(|_| TrustError::Decode(format!("expected {N} bytes")))
 }
