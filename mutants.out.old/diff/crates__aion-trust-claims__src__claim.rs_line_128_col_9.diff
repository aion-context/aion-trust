     pub fn issuer_id(&self) -> &Did {
         &self.issuer_id
     }
 
     pub fn claim_id(&self) -> &ClaimId {
-        &self.claim_id
+        Box::leak(Box::new(Default::default())) /* ~ changed by cargo-mutants ~ */
